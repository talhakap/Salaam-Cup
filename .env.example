# =============================================================
# Salaam Cup — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================

# --- DATABASE (required) ---
# Your PostgreSQL connection string.
# If using Supabase, find this in: Project Settings → Database → Connection string (URI)
# Use the "Session mode" URL (port 5432), NOT the "Transaction mode" (port 6543).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# If you want to use a separate DB URL for Drizzle migrations (optional):
# SUPABASE_DATABASE_URL=postgresql://...

# --- SUPABASE AUTH (required for admin + captain login) ---
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- SESSION (required) ---
# Any random string, minimum 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# --- ADMIN SETUP (required) ---
# Comma-separated list of email addresses that will be auto-provisioned as admins.
ADMIN_EMAILS=you@example.com

# Optional: set a specific password for the admin account(s).
# If omitted, a random password is generated and printed to the server logs on first start.
ADMIN_PASSWORD=

# --- EMAIL / GMAIL (optional) ---
# If not set, email notifications (team approval, password reset, etc.) will be disabled.
# Use a Gmail App Password — NOT your regular Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- SERVER (optional) ---
PORT=5000
NODE_ENV=production

# --- GOOGLE CLOUD STORAGE (optional) ---
# Only needed if you want cloud image storage instead of local disk.
# Local disk storage (attached_assets/uploads/) is used by default and works without these.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_PROJECT_ID=your-gcp-project-id
# PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket-name/public
# PRIVATE_OBJECT_DIR=/your-bucket-name/private
